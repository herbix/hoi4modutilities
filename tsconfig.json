{
	"compilerOptions": {
		"module": "es6",
		"moduleResolution": "node",
		"target": "es2018",
		"outDir": "out",
		"lib": [
			"es6",
			"DOM"
		],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"importHelpers": true
	},
	"exclude": [
		"node_modules",
		".vscode-test",
		"out",
		"scripts"
	]
}
